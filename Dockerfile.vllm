# ── Base ──────────────────────────────────────────────────────────────────────
# Build with: docker build --platform linux/amd64 -f Dockerfile.vllm -t vllm-krylov:latest .
# ARG lets us pass --platform at build time without triggering the linter warning.
ARG TARGETPLATFORM=linux/amd64
FROM hub.tess.io/krylov_curated_workspace/pytorch:2.6.0-cuda12.6-devel-py3.10-ubuntu22.04.latest

# ── Environment ───────────────────────────────────────────────────────────────
ENV DEBIAN_FRONTEND=noninteractive \
    PIP_NO_CACHE_DIR=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    UV_SYSTEM_PYTHON=1 \
    UV_LINK_MODE=copy \
    CUDA_HOME=/usr/local/cuda

# ── CUDA auxiliary libraries ───────────────────────────────────────────────────
# The base image holds libcudnn9-cuda-12, libnccl2, libnccl-dev at pinned versions.
# --allow-change-held-packages lets apt upgrade them to the latest available in
# the CUDA 12 repo (already configured in the base image).
RUN apt-get update && \
    apt-get install -y --no-install-recommends --allow-change-held-packages \
        libcudnn9-cuda-12 \
        libcudnn9-dev-cuda-12 \
        libnccl2 \
        libnccl-dev \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# ── uv + vLLM ─────────────────────────────────────────────────────────────────
RUN pip install --upgrade pip setuptools wheel uv && \
    uv pip install vllm

# ── Default entrypoint ────────────────────────────────────────────────────────
# NOTE: flash-attn is intentionally omitted. vLLM ships vllm-flash-attn as a
# pre-built dependency with matching CUDA/torch versions. Building flash-attn
# from source fails here because the base image torch was compiled against
# CUDA 13.0 while the system CUDA toolkit is 12.6.
# Override at runtime:
#   docker run --gpus all -p 8000:8000 <image> \
#       --model Qwen/Qwen3-8B --trust-remote-code --tensor-parallel-size 2
ENV MODEL_NAME=Qwen/Qwen3-8B

EXPOSE 8000

ENTRYPOINT ["python", "-m", "vllm.entrypoints.openai.api_server"]
CMD ["--model", "Qwen/Qwen3-8B", "--trust-remote-code"]
